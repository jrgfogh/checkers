{
  "name": "checkers",
  "version": "1.0.0",
  "description": "A simple in-browser checkers game.",
  "main": "checkers.js",
  "scripts": {
    "test": "jest",
    "test:watch": "jest --watch",
    "type-check": "tsc --noEmit",
    "start": "webpack-dev-server --content-base=src/ --mode development --progress --open --hot",
    "build": "webpack --mode production --progress",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,jsx,css}\" \"test/**/*.{ts,tsx,js,jsx}\""
  },
  "keywords": [
    "checkers",
    "js"
  ],
  "author": "Jørgen Fogh",
  "license": "LGPL-3.0-or-later",
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.2",
    "@babel/preset-react": "^7.28.5",
    "@babel/preset-typescript": "^7.28.5",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^30.0.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "babel-loader": "^10.1.1",
    "fork-ts-checker-webpack-plugin": "^9.0.2",
    "jest": "^30.3.0",
    "jest-each": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "prettier": "^3.2.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "ts-jest": "^29.1.1",
    "typescript": "^6.0.2",
    "webpack": "^5.105.4",
    "webpack-cli": "^7.0.0",
    "webpack-dev-server": "^5.2.3"
  }
}
